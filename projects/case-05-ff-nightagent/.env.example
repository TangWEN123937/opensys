# ─── FF-NightAgent · local dev ──────────────────────────────────
# All keys are optional. Without them, the app runs in MOCK mode
# (scripted event stream for safe demo / live coding).

# Claude Agent SDK (optional — enables real agent execution)
ANTHROPIC_API_KEY=

# Mem0 long-term memory (optional — falls back to local JSON)
MEM0_API_KEY=

# Dev server port (override)
PORT=3333
