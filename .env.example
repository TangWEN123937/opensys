# =====================================================================
#  OpenSys 环境变量配置
#  复制此文件为 .env 并填入实际值
#
#  标记说明：
#    [必填]  — 系统启动必须配置，否则对应功能不可用
#    [推荐]  — 强烈建议配置，有合理默认值但建议按需调整
#    [可选]  — 有默认值，一般无需修改
# =====================================================================


# ============================ 模型选择 ================================

# [必填] 默认主模型（必须是下方支持列表中的 key）
# 支持的模型：deepseek-chat, deepseek-reasoner,
#   qwen3.6-plus, qwen3.5-plus, qwen3.5-plus-Think, qwen3-coder-plus,
#   claude-sonnet-4-6, claude-haiku-4-5, gemini-3-flash-preview,
#   kimi-k2.5, MiniMax-M2.5, MiniMax-M2.7, glm-5.1, ollama-qwen3.5:9b
OPENSYS_MODEL_NAME=deepseek-chat

# [推荐] 复杂任务模型（Advisor 规划等高复杂度场景，默认 claude-sonnet-4-6）
# OPENSYS_COMPLEX_MODEL=claude-sonnet-4-6


# ======================== 子代理独立模型 ===============================
# 不设置则使用各自默认值；按需覆盖

# [可选] Executor 执行子任务（默认 deepseek-chat）
# OPENSYS_EXECUTOR_MODEL=deepseek-chat

# [可选] Dispatcher 拆分子任务（默认 deepseek-chat）
# OPENSYS_DISPATCHER_MODEL=deepseek-chat

# [可选] Reviewer 质量审查（默认 deepseek-chat）
# OPENSYS_REVIEWER_MODEL=deepseek-chat

# [可选] Advisor 规划（默认使用 COMPLEX_MODEL）
# OPENSYS_ADVISOR_MODEL=

# [推荐] Browser 浏览器代理（默认复用主模型）
# ⚠️ 必须使用支持视觉(Vision)的模型，Browser-Use 需要看页面截图来操作
# ✅ 支持视觉：qwen3.6-plus, qwen3.5-plus, claude-sonnet-4-6, claude-haiku-4-5,
#              gemini-3-flash-preview, kimi-k2.5, ollama-qwen3.5:9b
# ❌ 不支持视觉：deepseek-chat, deepseek-reasoner, glm-5.1,
#                MiniMax-M2.5, MiniMax-M2.7, qwen3-coder-plus
# OPENSYS_BROWSER_MODEL=qwen3.5-plus


# ======================== API Key 配置 ================================
# 只需填写你实际用到的提供商，未使用的留空即可

# --- DeepSeek ---
# [必填 - 如果使用 deepseek-chat / deepseek-reasoner]
OPENSYS_DEEPSEEK_API_KEY=
OPENSYS_DEEPSEEK_API_BASE=https://api.deepseek.com

# --- 通义千问 Qwen ---
# [必填 - 如果使用 qwen3.6-plus / qwen3.5-plus / qwen3-coder-plus 等]
OPENSYS_QWEN_API_KEY=
OPENSYS_QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- DashScope 百炼平台 ---
# [必填 - 如果使用 kimi-k2.5 / MiniMax-M2.5]
# 这两个模型通过阿里百炼平台调用，共用此 Key
OPENSYS_DASHSCOPE_API_KEY=

# --- MiniMax ---
# [必填 - 如果使用 MiniMax-M2.7]
# MiniMax-M2.7 使用 MiniMax 官方独立 API，非百炼平台
OPENSYS_MINIMAX_API_KEY=

# --- 智谱 GLM ---
# [必填 - 如果使用 glm-5.1]
OPENSYS_ZHIPU_API_KEY=

# --- Anthropic Claude ---
# [必填 - 如果使用 claude-sonnet-4-6 / claude-haiku-4-5]
OPENSYS_ANTHROPIC_API_KEY=
OPENSYS_ANTHROPIC_API_BASE=https://api.anthropic.com

# --- Google Gemini ---
# [必填 - 如果使用 gemini-3-flash-preview]
OPENSYS_GOOGLE_API_KEY=
OPENSYS_GOOGLE_API_BASE=

# --- Ollama 本地模型 ---
# [可选] 无需 API Key，仅需指定服务地址
OPENSYS_OLLAMA_API_BASE=http://localhost:11434


# ============================ Web 工具 ================================

# [推荐] Tavily 搜索 API Key（web_tool 搜索 + 网页提取功能依赖此 Key）
# 免费注册：https://tavily.com
TAVILY_API_KEY=

# [可选] 搜索返回结果数（默认 5）
# OPENSYS_WEB_SEARCH_MAX_RESULTS=5


# ============================ 安全授权 ================================

# [推荐] 授权等级（控制命令执行的审批策略）
#   0 = 观察者：只能查看，不能执行任何命令
#   1 = 受限（默认）：只读命令免审批，其他全部需要审批
#   2 = 标准：安全基线内免审批，危险操作需审批
#   3 = 信任：大部分操作免审批，仅高危操作需确认
#   4 = 自主：几乎全部自动执行，仅特殊场景通知
OPENSYS_AUTH_LEVEL=1


# ============================ 服务配置 ================================

# [可选] API 服务端口（默认 8000）
OPENSYS_API_PORT=8000

# [可选] API 服务绑定地址（默认 0.0.0.0）
# OPENSYS_API_HOST=0.0.0.0

# [可选] 数据目录（默认项目根目录下的 data/）
# OPENSYS_DATA_DIR=


# ============================ 浏览器配置 ==============================

# [可选] 无头模式（true=不显示浏览器窗口，默认 false 配合 noVNC 可视化）
# OPENSYS_BROWSER_HEADLESS=false

# [可选] 浏览器单次任务最大步数（默认 30）
# OPENSYS_BROWSER_MAX_STEPS=30

# [可选] 步骤用尽后自动续行次数（默认 1）
# OPENSYS_BROWSER_MAX_CONTINUATIONS=1

# [可选] 浏览器下载文件保存目录（默认 data/downloads/）
# OPENSYS_BROWSER_DOWNLOADS_DIR=

# [可选] noVNC 远程桌面端口（默认 6080）
# OPENSYS_NOVNC_PORT=6080


# ============================ 代理网关 ================================

# [可选] Squid 代理（Docker 部署时使用）
# OPENSYS_PROXY_HOST=host.docker.internal
# OPENSYS_PROXY_PORT=3128


# ============================ 高级配置 ================================
# 以下配置项一般无需修改，仅供高级用户调优

# [可选] 模型参数
# OPENSYS_TEMPERATURE=0.7
# OPENSYS_MAX_TOKENS=4096

# [可选] LangGraph 全局递归上限（默认 100）
# OPENSYS_RECURSION_LIMIT=100

# [可选] 无人值守模式超时秒数（定时任务用，默认 900 即 15 分钟）
# OPENSYS_UNATTENDED_TIMEOUT=900

# [可选] 无人值守最大自动处理 interrupt 次数（默认 10，防死循环）
# OPENSYS_UNATTENDED_MAX_INTERRUPTS=10

# [可选] Executor 单阶段最大返工次数（默认 2）
# OPENSYS_EXECUTOR_MAX_REWORK=2

# [可选] Advisor 单次会话最大调用次数（默认 5）
# OPENSYS_ADVISOR_MAX_CALLS=5

# [可选] 同一阶段最大路由次数（默认 5）
# OPENSYS_MAX_PHASE_ATTEMPTS=5

# [可选] Pipeline 模式下 Agent 单阶段最大工具调用轮次（默认 8）
# OPENSYS_AGENT_PHASE_MAX_TOOL_ROUNDS=8

# [可选] 上下文压缩触发阈值
# OPENSYS_COMPRESS_MSG_TRIGGER=60
# OPENSYS_COMPRESS_TOKEN_TRIGGER=15000
# OPENSYS_COMPRESS_KEEP_MSG=30

# [可选] 向量数据库配置
# OPENSYS_EMBEDDING_URL=http://localhost:8100/api/v1/embed
# OPENSYS_EMBEDDING_MODEL=bge-code-v1
# OPENSYS_VECTOR_TOP_K=5

# [可选] 调试模式（输出详细日志）
OPENSYS_DEBUG=false
