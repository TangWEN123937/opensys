# ==================== OpenSys 环境变量配置示例 ====================
# 复制此文件为 .env 并填入实际值

# --- 默认模型（必须是 MODEL_PRESETS 中的 key） ---
OPENSYS_MODEL_NAME=deepseek-chat

# --- 各提供商 API Key（按需填写，只填你用到的） ---
# DeepSeek
OPENSYS_DEEPSEEK_API_KEY=your-deepseek-key
OPENSYS_DEEPSEEK_API_BASE=

# 通义千问（Qwen / QwQ）
OPENSYS_QWEN_API_KEY=your-qwen-key
OPENSYS_QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Anthropic (Claude)
OPENSYS_ANTHROPIC_API_KEY=your-anthropic-key
OPENSYS_ANTHROPIC_API_BASE=

# Google (Gemini)
OPENSYS_GOOGLE_API_KEY=your-google-key
OPENSYS_GOOGLE_API_BASE=

# OpenAI (GPT)
OPENSYS_OPENAI_API_KEY=your-openai-key
OPENSYS_OPENAI_API_BASE=https://api.openai.com/v1

# Ollama（本地模型，无需 API Key）
OPENSYS_OLLAMA_API_BASE=http://localhost:11434

# --- 授权等级（0=观察者, 1=受限, 2=标准, 3=信任, 4=自主）---
OPENSYS_AUTH_LEVEL=1

# --- 代理网关（Squid）---
OPENSYS_PROXY_HOST=host.docker.internal
OPENSYS_PROXY_PORT=3128

# --- 服务端口 ---
OPENSYS_API_PORT=8000

# --- 调试模式 ---
OPENSYS_DEBUG=false
